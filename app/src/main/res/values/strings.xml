    <string name="app_name">Breath Space</string>
    <string name="app_description">마음의 안식을 위한 깊고 고요한 심호흡 공간</string>

    <!-- Onboarding -->
    <string name="onboarding_title_0">잠시 멈춰도 괜찮아요.</string>
    <string name="onboarding_title_1">지금은 숨을 고르는 시간이에요.</string>
    <string name="onboarding_title_2">당신의 호흡에 맞춰 천천히 움직여볼게요.</string>
    <string name="onboarding_desc_0">바쁜 하루 마음에 쉼표가 필요할 때, 우리는 늘 이곳에 있습니다.</string>
    <string name="onboarding_desc_1">눈을 감고 온전히 자신에게 집중해보세요. 짧은 호흡만으로도 충분합니다.</string>
    <string name="onboarding_desc_2">하루 중 잠깐의 쉼이 필요한 순간에 조용히 알려드릴게요.</string>
    <string name="allow_notifications_prompt">하루 중 잠깐의 쉼이 필요한 순간에 알려드릴게요.</string>
